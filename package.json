{
  "name": "gns-hermit-comm",
  "version": "1.0.0",
  "description": "A social media app for sharing stories and connecting with others in a hermit community",
  "main": "index.tsx",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "node scripts/run-maestro.js test .maestro",
    "test:e2e:resume": "node scripts/run-maestro.js test .maestro --resume",
    "test:e2e:admin": "node scripts/run-maestro.js test .maestro/admin-login.yaml .maestro/admin-create-group.yaml .maestro/admin-logout.yaml",
    "test:e2e:invite": "node scripts/run-maestro.js test .maestro/admin-create-group-invite-test.yaml .maestro/groups-join-by-invite.yaml",
    "prepare": "husky",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "update:preview": "eas update --channel preview",
    "update:production": "eas update --channel production",
    "db:migration-list": "supabase migration list",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@10play/tentap-editor": "^1.0.1",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/query-persist-client-core": "^5.91.19",
    "@tanstack/react-query": "^5.62.0",
    "date-fns": "^4.1.0",
    "expo": "~55.0.5",
    "expo-blur": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.12",
    "expo-insights": "~55.0.10",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.13",
    "nativewind": "^4.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.54.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "^0.2.1",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-reanimated": "4.2.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-webview": "^13.12.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "babel-preset-expo": "^55.0.11",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "jest": "29.7.0",
    "jest-expo": "~55.0.9",
    "lint-staged": "^15.2.10",
    "prettier": "^3.2.4",
    "react-native-worklets": "^0.7.2",
    "react-test-renderer": "^19.2.0",
    "tailwindcss": "3.4.19",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@10play/tentap-editor": {
      "react-dom": "$react-dom"
    }
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
